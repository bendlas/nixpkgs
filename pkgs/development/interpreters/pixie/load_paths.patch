+  (let [tempdir (mkdtemp tempdir-template)
+        infile (str tempdir "/ffi.cpp")
+        outfile (str tempdir "/ffi.out")]
+    (io/spit infile (str (start-string)
+                         (apply str (map emit-infer-code
+                                         cmds))
+                         (end-string)))
+    (println @load-paths)
+    (let [cmd-str (str "c++ "
+                       (apply str (interpose " " pixie.platform/c-flags))
