+          _ (println cmd-str)
+          result (read-string (io/run-command cmd-str))
+          gen (vec (map generate-code cmds result))]
+      (unlink infile)
+      (unlink outfile)
+      (rmdir tempdir)
+      `(do ~@gen))))
 
 (defn full-lib-name [library-name]
